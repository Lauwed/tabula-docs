{
  "settings": {
    "title": "Date.now()",
    "description": "API for the blog and CMS of Date.now()",
    "version": "1.0.0",
    "baseUrl": "/api",
    "theme": {
      "accent": "#1d9e75",
      "accentLight": "#e1f5ee",
      "accentDark": "#085041",
      "colorGet": "#1a5fa8",
      "colorPost": "#6b3a9e",
      "colorPut": "#b84a0e",
      "colorDelete": "#a8192e",
      "fontBody": "\"General Sans\", sans-serif",
      "fontMono": "\"JetBrainsMono Nerd\", monospace"
    },
    "darkTheme": {
      "accent": "#2ec48f",
      "accentLight": "#04342c",
      "accentDark": "#a8f0d4",
      "colorGet": "#5b9fd6",
      "colorPost": "#a67dd4",
      "colorPut": "#e07a45",
      "colorDelete": "#d95f72"
    }
  },
  "defaultErrors": [
    {
      "code": 400,
      "response": {
        "code": 400,
        "message": "Invalid or missing fields"
      },
      "appliesTo": ["POST", "PUT"]
    },
    {
      "code": 401,
      "response": {
        "code": 401,
        "message": "Unauthorized, valid token required"
      },
      "appliesTo": ["POST", "PUT", "DELETE"]
    },
    {
      "code": 403,
      "response": {
        "code": 403,
        "message": "Forbidden, insufficient permissions"
      },
      "appliesTo": ["POST", "PUT", "DELETE"]
    },
    {
      "code": 404,
      "response": {
        "code": 404,
        "message": "Resource not found"
      },
      "appliesTo": ["GET-single", "PUT", "DELETE"]
    },
    {
      "code": 500,
      "response": {
        "code": 500,
        "message": "Internal server error"
      },
      "appliesTo": [
        "GET-list",
        "GET-single",
        "POST",
        "PUT",
        "DELETE"
      ]
    }
  ],
  "tables": [
    {
      "name": {
        "singular": "authentication",
        "plural": "authentication"
      },
      "description": "Author authentication via magic link and TOTP. Also handles newsletter subscriber registration and confirmation.",
      "uri": "/auth",
      "includedEndpoints": [],
      "customEndpoints": [
        {
          "name": "subscribe",
          "description": "Sends a confirmation email to the provided address to subscribe to the newsletter.",
          "uri": "/subscribe",
          "method": "POST",
          "tokenRequired": false,
          "body": { "email": "string" },
          "responses": [
            {
              "code": 200,
              "response": { "message": "Confirmation mail sent" }
            },
            {
              "code": 400,
              "response": {
                "code": 400,
                "message": "Invalid email address"
              }
            },
            {
              "code": 409,
              "response": {
                "code": 409,
                "message": "Email already subscribed"
              }
            },
            {
              "code": 429,
              "response": {
                "code": 429,
                "message": "Too many requests, please try again later"
              }
            },
            500
          ]
        },
        {
          "name": "confirm subscribe",
          "description": "Confirms a subscription via the token received by email. The token is single-use and expires after a delay.",
          "uri": "/subscribe/confirm",
          "method": "GET",
          "tokenRequired": false,
          "queryParameters": [
            {
              "label": "Token",
              "name": "token",
              "type": "string",
              "required": true
            }
          ],
          "responses": [
            {
              "code": 200,
              "response": {
                "message": "User successfully subscribed"
              }
            },
            {
              "code": 400,
              "response": {
                "code": 400,
                "message": "Invalid or expired token"
              }
            },
            {
              "code": 404,
              "response": {
                "code": 404,
                "message": "User not found"
              }
            },
            {
              "code": 409,
              "response": {
                "code": 409,
                "message": "User already subscribed"
              }
            },
            500
          ]
        },
        {
          "name": "generate author totp seed",
          "description": "Generates a TOTP seed for an existing author account. Requires a valid JWT token. Useful for resetting an author's TOTP access.",
          "uri": "/seed",
          "method": "POST",
          "tokenRequired": true,
          "body": { "email": "string" },
          "responses": [
            {
              "code": 200,
              "response": {
                "message": "TOTP seed successfully generated",
                "totpseed": "string"
              }
            },
            {
              "code": 400,
              "response": {
                "code": 400,
                "message": "Invalid email address"
              }
            },
            401,
            403,
            {
              "code": 404,
              "response": {
                "code": 404,
                "message": "Author not found"
              }
            },
            500
          ]
        },
        {
          "name": "author registration",
          "description": "Creates a new author account (role AUTHOR) and returns the TOTP seed to configure in an authenticator app (e.g. Google Authenticator).",
          "uri": "/register",
          "method": "POST",
          "tokenRequired": true,
          "body": { "username": "string", "email": "string" },
          "responses": [
            {
              "code": 201,
              "response": {
                "message": "Author successfully registered",
                "totpseed": "string"
              }
            },
            400,
            401,
            403,
            {
              "code": 409,
              "response": {
                "code": 409,
                "message": "Email already registered"
              }
            },
            500
          ]
        },
        {
          "name": "author login",
          "description": "Sends a magic link to the author's email address. The link redirects to the TOTP validation step.",
          "uri": "/login",
          "method": "POST",
          "tokenRequired": false,
          "body": { "email": "string" },
          "responses": [
            {
              "code": 200,
              "response": {
                "message": "Magic link sent to email"
              }
            },
            {
              "code": 400,
              "response": {
                "code": 400,
                "message": "Invalid email address"
              }
            },
            {
              "code": 404,
              "response": {
                "code": 404,
                "message": "Author not found"
              }
            },
            {
              "code": 429,
              "response": {
                "code": 429,
                "message": "Too many requests, please try again later"
              }
            },
            500
          ]
        },
        {
          "name": "TOTP login",
          "description": "Validates the 6-digit TOTP code and returns a JWT token to use in the Authorization header of authenticated requests.",
          "uri": "/login/totp",
          "method": "POST",
          "tokenRequired": false,
          "body": { "token": "string", "code": "string" },
          "responses": [
            {
              "code": 200,
              "response": {
                "message": "Successfully logged in",
                "token": "string"
              }
            },
            {
              "code": 400,
              "response": {
                "code": 400,
                "message": "Invalid or expired TOTP code"
              }
            },
            {
              "code": 404,
              "response": {
                "code": 404,
                "message": "User not found"
              }
            },
            {
              "code": 429,
              "response": {
                "code": 429,
                "message": "Too many failed attempts, please try again later"
              }
            },
            500
          ]
        }
      ]
    },
    {
      "name": {
        "singular": "media",
        "plural": "medias"
      },
      "description": "Media files (images) uploaded and automatically converted to WebP. Accessible at /uploads/media/{uuid}/image.webp.",
      "uri": "/media",
      "uriParameters": [
        {
          "name": "id",
          "type": "integer",
          "defaultValue": 1,
          "isPrimary": true
        }
      ],
      "schema": {
        "id": "integer",
        "textAlternatif": "string",
        "url": "string",
        "width": "double?",
        "height": "double?"
      },
      "response": {
        "get-list": {
          "data": "array-media",
          "total": "integer",
          "page": "integer",
          "pageSize": "integer"
        },
        "get-single": {
          "id": "integer",
          "textAlternatif": "string",
          "url": "string",
          "width": "double?",
          "height": "double?"
        }
      },
      "listParameters": [
        {
          "name": "page",
          "label": "Page",
          "type": "integer",
          "defaultValue": 1,
          "min": 1
        },
        {
          "name": "limit",
          "label": "Limit",
          "type": "integer",
          "defaultValue": 20,
          "min": 1,
          "max": 100
        }
      ],
      "endpoints": {
        "GET-list": {
          "description": "Returns the paginated list of media files."
        },
        "GET-single": {
          "description": "Returns a media file by its ID."
        },
        "POST": {
          "description": "Uploads an image. The file is automatically converted to WebP.",
          "includedErrors": [401, 500],
          "body": {
            "multipart": true,
            "fields": [
              {
                "name": "textAlternatif",
                "label": "Alternative text",
                "type": "string",
                "required": true
              },
              {
                "name": "file",
                "label": "File",
                "type": "file",
                "required": true,
                "accept": ["image/*"],
                "maxWeight": 10
              }
            ]
          },
          "responses": [
            {
              "code": 201,
              "response": {
                "id": "integer",
                "textAlternatif": "string",
                "url": "string",
                "width": "double?",
                "height": "double?"
              }
            },
            {
              "code": 413,
              "response": {
                "code": 413,
                "message": "File too large, maximum size is 5 MB"
              }
            },
            {
              "code": 415,
              "response": {
                "code": 415,
                "message": "Unsupported media type"
              }
            }
          ]
        },
        "PUT": {
          "description": "Updates the alternative text of an existing media file.",
          "body": {
            "schema": { "textAlternatif": "string" },
            "defaultValue": "{\n\t\"textAlternatif\": \"My image\"\n}"
          },
          "responses": [
            {
              "code": 200,
              "response": {
                "id": "integer",
                "textAlternatif": "string",
                "url": "string",
                "width": "double?",
                "height": "double?"
              }
            }
          ]
        },
        "DELETE": {
          "description": "Deletes a media file. Fails if the file is still referenced by an issue.",
          "responses": [
            {
              "code": 200,
              "response": {
                "message": "Media successfully deleted"
              }
            },
            {
              "code": 409,
              "response": {
                "code": 409,
                "message": "Media is referenced by one or more resources and cannot be deleted"
              }
            }
          ]
        }
      }
    },
    {
      "name": {
        "singular": "user",
        "plural": "users"
      },
      "description": "Newsletter subscribers and authors. Authors can log in and manage issues; subscribers receive the newsletter.",
      "uri": "/user",
      "uriParameters": [
        {
          "name": "id",
          "type": "integer",
          "defaultValue": 1,
          "isPrimary": true
        }
      ],
      "schema": {
        "id": "integer",
        "username": "string?",
        "email": "string",
        "role": "USER | AUTHOR",
        "link": "string?",
        "picture": "foreignKey-media",
        "subscribedAt": "timestamp?",
        "isSupporter": "boolean",
        "createdAt": "timestamp"
      },
      "response": {
        "get-list": {
          "data": "array-user",
          "total": "integer",
          "page": "integer",
          "pageSize": "integer"
        },
        "get-single": {
          "id": "integer",
          "username": "string?",
          "email": "string",
          "role": "USER | AUTHOR",
          "link": "string?",
          "picture": "foreignKey-media",
          "subscribedAt": "timestamp?",
          "isSupporter": "boolean",
          "createdAt": "timestamp",
          "issues": "array-issue"
        }
      },
      "listParameters": [
        {
          "name": "page",
          "label": "Page",
          "type": "integer",
          "defaultValue": 1,
          "min": 1
        },
        {
          "name": "limit",
          "label": "Limit",
          "type": "integer",
          "defaultValue": 20,
          "min": 1,
          "max": 100
        },
        {
          "name": "role",
          "label": "Role",
          "type": "select",
          "options": [
            { "name": "USER", "label": "Subscriber" },
            { "name": "AUTHOR", "label": "Author" }
          ]
        }
      ],
      "endpoints": {
        "GET-list": {
          "description": "Returns the paginated list of users. The totpSeed field is never exposed."
        },
        "GET-single": {
          "description": "Returns a user by their ID. The totpSeed field is never exposed."
        },
        "POST": {
          "description": "Creates a new user. To create an author with TOTP, use the /auth/register endpoint.",
          "body": {
            "schema": {
              "username": "string?",
              "email": "string",
              "role": "USER | AUTHOR",
              "link": "string?",
              "picture": "integer?"
            },
            "defaultValue": "{\n\t\"username\": \"DevGirl_\",\n\t\"email\": \"contact@lauradurieux.dev\",\n\t\"role\": \"AUTHOR\",\n\t\"link\": \"hihihuhuh.com\"\n}"
          },
          "responses": [
            {
              "code": 201,
              "response": {
                "id": "integer",
                "username": "string?",
                "email": "string",
                "role": "USER | AUTHOR",
                "link": "string?",
                "picture": "foreignKey-media",
                "subscribedAt": "timestamp?",
                "isSupporter": "boolean",
                "createdAt": "timestamp"
              }
            },
            {
              "code": 409,
              "response": {
                "code": 409,
                "message": "Email already registered"
              }
            }
          ]
        },
        "PUT": {
          "description": "Updates an existing user.",
          "body": {
            "schema": {
              "username": "string?",
              "email": "string",
              "role": "USER | AUTHOR",
              "link": "string?",
              "subscribedAt": "timestamp?",
              "isSupporter": "boolean",
              "picture": "integer?"
            }
          },
          "responses": [
            {
              "code": 200,
              "response": {
                "id": "integer",
                "username": "string?",
                "email": "string",
                "role": "USER | AUTHOR",
                "link": "string?",
                "picture": "foreignKey-media",
                "subscribedAt": "timestamp?",
                "isSupporter": "boolean",
                "createdAt": "timestamp"
              }
            },
            {
              "code": 409,
              "response": {
                "code": 409,
                "message": "Email already in use"
              }
            }
          ]
        },
        "DELETE": {
          "description": "Deletes a user. IssueAuthor associations are deleted in cascade."
        }
      }
    },
    {
      "name": {
        "singular": "tag",
        "plural": "tags"
      },
      "description": "Tags used to categorize newsletter issues. Identified by their name (primary key, max 64 characters).",
      "uri": "/tag",
      "uriParameters": [
        {
          "name": "name",
          "type": "string",
          "defaultValue": "Computer Science",
          "isPrimary": true
        }
      ],
      "schema": {
        "name": "string",
        "color": "string"
      },
      "includedEndpoints": [
        "GET-list",
        "GET-single",
        "POST",
        "PUT",
        "DELETE"
      ],
      "endpoints": {
        "GET-list": {
          "description": "Returns all available tags."
        },
        "GET-single": {
          "description": "Returns a tag by its name."
        },
        "POST": {
          "description": "Creates a new tag. The name is the primary key (max 64 characters) and cannot be changed after creation.",
          "body": {
            "schema": { "name": "string", "color": "string" },
            "defaultValue": "{\n\t\"name\": \"Computer Science\",\n\t\"color\": \"#6b3a9e\"\n}"
          },
          "responses": [
            {
              "code": 201,
              "response": { "name": "string", "color": "string" }
            },
            {
              "code": 409,
              "response": {
                "code": 409,
                "message": "Tag already exists"
              }
            }
          ]
        },
        "PUT": {
          "description": "Updates the color of an existing tag.",
          "body": {
            "schema": { "color": "string" },
            "defaultValue": "{\n\t\"color\": \"#123456\"\n}"
          },
          "responses": [
            {
              "code": 200,
              "response": { "name": "string", "color": "string" }
            }
          ]
        },
        "DELETE": {
          "description": "Deletes a tag. IssueTag associations are deleted in cascade."
        }
      }
    },
    {
      "name": {
        "singular": "sponsor",
        "plural": "sponsors"
      },
      "description": "Sponsors associated with newsletter issues. Identified by their name (primary key). The link specific to an issue is stored in the IssueSponsor table.",
      "uri": "/sponsor",
      "uriParameters": [
        {
          "name": "name",
          "type": "string",
          "defaultValue": "Firefox",
          "isPrimary": true
        }
      ],
      "schema": {
        "name": "string",
        "link": "string"
      },
      "includedEndpoints": [
        "GET-list",
        "GET-single",
        "POST",
        "PUT",
        "DELETE"
      ],
      "endpoints": {
        "GET-list": {
          "description": "Returns all sponsors."
        },
        "GET-single": {
          "description": "Returns a sponsor by its name."
        },
        "POST": {
          "description": "Creates a new sponsor. The name is the primary key and cannot be changed after creation.",
          "body": {
            "schema": { "name": "string", "link": "string" },
            "defaultValue": "{\n\t\"name\": \"Firefox\",\n\t\"link\": \"firefox.com\"\n}"
          },
          "responses": [
            {
              "code": 201,
              "response": { "name": "string", "link": "string" }
            },
            {
              "code": 409,
              "response": {
                "code": 409,
                "message": "Sponsor already exists"
              }
            }
          ]
        },
        "PUT": {
          "description": "Updates the default link of an existing sponsor.",
          "body": {
            "schema": { "link": "string" },
            "defaultValue": "{\n\t\"link\": \"firefox.com\"\n}"
          },
          "responses": [
            {
              "code": 200,
              "response": { "name": "string", "link": "string" }
            }
          ]
        },
        "DELETE": {
          "description": "Deletes a sponsor. IssueSponsor associations are deleted in cascade."
        }
      }
    },
    {
      "name": {
        "singular": "issue",
        "plural": "issues"
      },
      "description": "Newsletter issues — drafts, published, and archived. Each issue has rich content, a cover image, authors, tags, and sponsors.",
      "uri": "/issue",
      "uriParameters": [
        {
          "name": "id",
          "type": "integer",
          "defaultValue": 1,
          "isPrimary": true
        }
      ],
      "schema": {
        "id": "integer",
        "slug": "string",
        "title": "string",
        "subtitle": "string",
        "cover": "foreignKey-media",
        "createdAt": "timestamp",
        "publishedAt": "timestamp?",
        "updatedAt": "timestamp?",
        "issueNumber": "integer",
        "excerpt": "string",
        "content": "string",
        "isSponsored": "boolean",
        "status": "DRAFT | PUBLISHED | ARCHIVE",
        "openedMailCount": "integer"
      },
      "includedEndpoints": [
        "GET-list",
        "GET-single",
        "POST",
        "PUT",
        "DELETE"
      ],
      "response": {
        "get-list": {
          "data": "array-issue",
          "total": "integer",
          "page": "integer",
          "pageSize": "integer"
        },
        "get-single": {
          "id": "integer",
          "slug": "string",
          "title": "string",
          "subtitle": "string",
          "cover": "foreignKey-media",
          "createdAt": "timestamp",
          "publishedAt": "timestamp?",
          "updatedAt": "timestamp?",
          "issueNumber": "integer",
          "excerpt": "string",
          "content": "string",
          "isSponsored": "boolean",
          "status": "DRAFT | PUBLISHED | ARCHIVE",
          "openedMailCount": "integer",
          "views": "integer",
          "authors": "array-user",
          "tags": "array-tag",
          "sponsors": "array-sponsor"
        }
      },
      "listParameters": [
        {
          "name": "page",
          "label": "Page",
          "type": "integer",
          "defaultValue": 1,
          "min": 1
        },
        {
          "name": "limit",
          "label": "Limit",
          "type": "integer",
          "defaultValue": 20,
          "min": 1,
          "max": 100
        },
        {
          "name": "status",
          "label": "Status",
          "type": "select",
          "options": [
            { "name": "DRAFT", "label": "Draft" },
            { "name": "PUBLISHED", "label": "Published" },
            { "name": "ARCHIVE", "label": "Archived" }
          ]
        }
      ],
      "endpoints": {
        "GET-list": {
          "description": "Returns the paginated list of issues, optionally filtered by status."
        },
        "GET-single": {
          "description": "Returns an issue by its ID, including its authors, tags, and sponsors."
        },
        "POST": {
          "description": "Creates a new issue. The slug is auto-generated from the title if not provided. The issue number must be unique.",
          "body": {
            "schema": {
              "slug": "string?",
              "title": "string",
              "subtitle": "string",
              "issueNumber": "integer",
              "excerpt": "string",
              "content": "string",
              "isSponsored": "boolean?",
              "status": "DRAFT | PUBLISHED | ARCHIVE",
              "cover": "integer?"
            },
            "defaultValue": "{\n\t\"title\": \"My first issue\",\n\t\"subtitle\": \"A great subtitle\",\n\t\"issueNumber\": 1,\n\t\"excerpt\": \"A short excerpt\",\n\t\"content\": \"Full content here\",\n\t\"status\": \"DRAFT\"\n}"
          },
          "responses": [
            {
              "code": 201,
              "response": {
                "id": "integer",
                "slug": "string",
                "title": "string",
                "subtitle": "string",
                "cover": "foreignKey-media",
                "createdAt": "timestamp",
                "issueNumber": "integer",
                "excerpt": "string",
                "content": "string",
                "isSponsored": "boolean",
                "status": "DRAFT | PUBLISHED | ARCHIVE",
                "openedMailCount": "integer"
              }
            },
            {
              "code": 409,
              "response": {
                "code": 409,
                "message": "Issue number already exists"
              }
            }
          ]
        },
        "PUT": {
          "description": "Updates an existing issue. All fields are required.",
          "body": {
            "schema": {
              "slug": "string?",
              "title": "string",
              "subtitle": "string",
              "issueNumber": "integer",
              "excerpt": "string",
              "content": "string",
              "isSponsored": "boolean?",
              "status": "DRAFT | PUBLISHED | ARCHIVE",
              "cover": "integer?"
            },
            "defaultValue": "{\n\t\"title\": \"My first issue\",\n\t\"subtitle\": \"A great subtitle\",\n\t\"issueNumber\": 1,\n\t\"excerpt\": \"A short excerpt\",\n\t\"content\": \"Full content here\",\n\t\"status\": \"DRAFT\"\n}"
          },
          "responses": [
            {
              "code": 200,
              "response": {
                "id": "integer",
                "slug": "string",
                "title": "string",
                "subtitle": "string",
                "cover": "foreignKey-media",
                "createdAt": "timestamp",
                "publishedAt": "timestamp?",
                "updatedAt": "timestamp?",
                "issueNumber": "integer",
                "excerpt": "string",
                "content": "string",
                "isSponsored": "boolean",
                "status": "DRAFT | PUBLISHED | ARCHIVE",
                "openedMailCount": "integer"
              }
            },
            {
              "code": 409,
              "response": {
                "code": 409,
                "message": "Issue number already in use by another issue"
              }
            }
          ]
        },
